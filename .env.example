# ─────────────────────────────────────────────────────────────────────────────
# Database connection settings (Neon/PostgreSQL)
#
# IMPORTANT — ONE DATABASE PER GIT BRANCH.
# Do NOT share a single Neon database across feature branches. Branches have
# different schemas, so a shared DB causes `prisma db push` to drop the other
# branch's tables/columns (the "RiskReview does not exist" class of crash).
#
# Each developer / each feature branch should use its OWN Neon branch:
#   1. Neon console -> your project -> Branches -> "Create branch" (off main).
#   2. Copy that branch's pooled connection string into DATABASE_URL below,
#      and its direct (non-pooled) string into DIRECT_URL.
#   3. `npm run dev` auto-runs `prisma db push` to match your branch's schema.
#      Then `npm run seed` to load demo data.
# Neon branches are copy-on-write (instant, free tier) — make one per branch.
# This file is committed; your real .env is gitignored. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────
# Use connect_timeout=15 for serverless databases to prevent cold-start timeouts
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require&connect_timeout=15"

# NextAuth configuration
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Storage Settings ("local" or "s3")
STORAGE_PROVIDER="local"

# Google Auth Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Gemini API Key (multimodal/vision document extraction)
GEMINI_API_KEY="your-gemini-api-key"

# Surepass PAN Verification API (https://surepass.io)
# Leave blank to run in mock mode (always valid). Set token to activate live PAN verification.
SUREPASS_API_TOKEN=

# Admin reminder emails
# ADMIN_EMAIL is the inbox where all admin digest/reminder emails are sent
ADMIN_EMAIL="your-admin-email@example.com"

# CRON_SECRET protects the /api/cron/reminders endpoint
# Set this to a long random string and pass it as the x-cron-secret header when calling from your cron job
CRON_SECRET="your-long-random-secret"
